# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# Set to a long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Set to False in production.
DJANGO_DEBUG=True

# Comma-separated hostnames the app is allowed to serve.
# In dev, localhost is fine.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. If unset, SQLite at <BASE_DIR>/db.sqlite3 is used.
# When public hosting is added (futureplans.md #3), set this to e.g.:
#   postgres://user:pass@host:5432/dbname
# DATABASE_URL=
