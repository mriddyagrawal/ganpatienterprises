# Copy this file to `.env` and fill in real values.
# `.env` is gitignored.

# Set to a long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Set to False in production.
DJANGO_DEBUG=True

# Comma-separated hostnames the app is allowed to serve.
# - In dev, leaving this unset is usually fine: settings/dev.py defaults
#   to ["localhost", "127.0.0.1", "0.0.0.0", ".local"] which covers
#   loopback access plus any *.local mDNS hostname (e.g. mriddy.local:8000
#   from a phone on the same Wi-Fi).
# - If you want to expose the dev server over LAN by literal IP too
#   (Android phones sometimes don't resolve .local), set it here, e.g.:
#       DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mriddy.local,192.168.29.150
# - And remember to start the server bound to all interfaces:
#       python manage.py runserver 0.0.0.0:8000
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. If unset, SQLite at <BASE_DIR>/db.sqlite3 is used.
# When public hosting is added (futureplans.md #3), set this to e.g.:
#   postgres://user:pass@host:5432/dbname
# DATABASE_URL=
