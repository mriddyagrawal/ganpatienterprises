# Environment / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
/build/
/dist/
*.egg

# Virtual envs (managed by uv)
.venv/
venv/
env/

# uv keeps uv.lock and .python-version committed for reproducibility;
# its own caches are not.
.uv/

# Django
db.sqlite3
db.sqlite3-journal
/staticfiles/
/media/

# Tailwind build output (theme/static/css/dist/) is intentionally NOT ignored
# so a fresh clone runs without a build step. Regenerate with:
#   uv run python manage.py tailwind build

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
